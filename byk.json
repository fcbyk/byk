{
  "$var": {
    "url": "https://github.com/fcbyk/byk/releases/download/assets"
  },
  "$default": "test1",
  "test1": {
    "pip": [
      "byk_pym @ {url}/byk_pym-2026.6.21-py3-none-any.whl"
    ],
    "commands": {
      "hello1": {
        "type": "python-m",
        "entry": "bykpym.one",
        "desc": "example plugin for py-module one"
      },
      "hello2": {
        "type": "python-m",
        "entry": "bykpym.two",
        "desc": "example plugin for py-module two"
      }
    }
  },
  "test2": {
    "download-scripts": {
      "hello_world.py": "plugins/py-script/hello_world.py"
    },
    "command": {
      "type": "python",
      "entry": "hello_world.py",
      "desc": "example plugin for py-script"
    }
  },
  "test3": {
    "pip": [
      "byk_pyb @ {url}/byk_pyb-2026.6.22-py3-none-any.whl"
    ],
    "command": {
      "type": "pip-bin",
      "entry": "hello4",
      "desc": "example plugin for py-bin"
    }
  }
}