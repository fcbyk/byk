{
  "name": "byk-alias-runner",
  "displayName": "Byk Alias Runner",
  "description": "Run alias scripts from *.byk.json files with right-click menu",
  "version": "2026.6.10",
  "publisher": "fcbyk",
  "license": "MIT",
  "main": "./out/extension.js",
  "icon": "./assets/logo.png",
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "download-binary": "node scripts/download-binary.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.5.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fcbyk/byk",
    "directory": "extensions/vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "workspaceContains:**/*.byk.json"
  ],
  "contributes": {
    "configuration": {
      "title": "Byk Alias Runner",
      "properties": {
        "byk.useSystemBinary": {
          "type": "boolean",
          "default": false,
          "description": "优先使用系统 PATH 中的 byk 二进制文件"
        },
        "byk.binaryPath": {
          "type": "string",
          "default": "",
          "description": "自定义 byk 二进制文件的完整路径。设置后将优先使用此路径，支持 ~ 展开"
        }
      }
    },
    "taskDefinitions": [
      {
        "type": "byk",
        "required": [],
        "properties": {}
      }
    ],
    "commands": [
      {
        "command": "byk-alias.runAtCursor",
        "title": "Run Alias (Exact)",
        "icon": "$(run)"
      },
      {
        "command": "byk-alias.runScript",
        "title": "Choose Alias…"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": "*.byk.json",
        "url": "./schemas/byk-alias.json"
      },
      {
        "fileMatch": "byk.json",
        "url": "./schemas/byk-plugin.json"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "byk-alias.runScript",
          "when": "resourceFilename =~ /\\.byk\\.json$/",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "byk-alias.runAtCursor",
          "when": "resourceFilename =~ /\\.byk\\.json$/",
          "group": "navigation@1"
        },
        {
          "command": "byk-alias.runScript",
          "when": "resourceFilename =~ /\\.byk\\.json$/",
          "group": "navigation@2"
        }
      ],
      "editor/title/context": [
        {
          "command": "byk-alias.runAtCursor",
          "when": "resourceFilename =~ /\\.byk\\.json$/",
          "group": "navigation@1"
        },
        {
          "command": "byk-alias.runScript",
          "when": "resourceFilename =~ /\\.byk\\.json$/",
          "group": "navigation@2"
        }
      ]
    }
  }
}