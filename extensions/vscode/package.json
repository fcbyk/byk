{
  "name": "byk",
  "displayName": "BYK",
  "description": "BYK CLI integration for VS Code — run tasks, manage plugins, and validate configs",
  "version": "2026.6.10",
  "publisher": "fcbyk",
  "license": "MIT",
  "main": "./out/extension.js",
  "icon": "./assets/logo.png",
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "download-binary": "node scripts/download-binary.mjs",
    "download-assets": "node scripts/download-assets.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.5.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fcbyk/byk",
    "directory": "extensions/vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "workspaceContains:**/*.byk.json"
  ],
  "contributes": {
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "byk.useSystemBinary": {
          "type": "boolean",
          "default": false,
          "description": "%byk.useSystemBinary.description%"
        },
        "byk.binaryPath": {
          "type": "string",
          "default": "",
          "description": "%byk.binaryPath.description%"
        }
      }
    },
    "taskDefinitions": [
      {
        "type": "byk",
        "required": [],
        "properties": {}
      }
    ],
    "commands": [
      {
        "command": "byk.runAtCursor",
        "title": "%command.runAtCursor.title%",
        "icon": "$(run)"
      },
      {
        "command": "byk.runScript",
        "title": "%command.runScript.title%"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": "*.byk.json",
        "url": "./schemas/byk-alias.json"
      },
      {
        "fileMatch": "byk.json",
        "url": "./schemas/byk-plugin.json"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "byk.runScript",
          "when": "resourceFilename =~ /\\.byk\\.json$/",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "byk.runAtCursor",
          "when": "resourceFilename =~ /\\.byk\\.json$/",
          "group": "navigation@1"
        },
        {
          "command": "byk.runScript",
          "when": "resourceFilename =~ /\\.byk\\.json$/",
          "group": "navigation@2"
        }
      ],
      "editor/title/context": [
        {
          "command": "byk.runAtCursor",
          "when": "resourceFilename =~ /\\.byk\\.json$/",
          "group": "navigation@1"
        },
        {
          "command": "byk.runScript",
          "when": "resourceFilename =~ /\\.byk\\.json$/",
          "group": "navigation@2"
        }
      ]
    }
  }
}