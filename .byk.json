{
    "$priority": -1,
    "开发":{
        "测试": "cargo test",
        "覆盖率报告": "cargo llvm-cov",
        "运行": "cargo run",
        "构建": "cargo build --release",
        "安装": "ln -sf $(pwd)/target/debug/byk /opt/homebrew/bin/byk",
        "清空缓存": "hash -r",
        "显示": "ls -la /opt/homebrew/bin/byk && echo '---' && echo \"$PATH\" | tr ':' '\n' | nl",
        "卸载": "rm /opt/homebrew/bin/byk"
    },

    "git": {
        "查看本地标签": "git tag",
        "查看远程库标签": "git ls-remote --tags origin",
        "推送标签到远程库": "git push origin --tags",
        "撤销上一次提交": "git reset --soft HEAD~1"
    },

    "curl脚本": {
        "安装": "bash scripts/install.sh",
        "显示": "ls -a ~/.byk/bin",
        "卸载-保留数据": "rm ~/.byk/bin/byk",
        "卸载": "bash scripts/uninstall.sh"
    },

    "发布": {
        "maturin": {
            "打包arm": "maturin build --release --out dist",
            "打包x86": "maturin build --release --out dist --target x86_64-apple-darwin",
            "源码包": "maturin sdist --out dist"
        },
        "生成变更日志": "cz changelog --incremental",
        "更新版本号": {
            "$interactive": true,
            "$cmd": "cz bump {version}"
        },
        "检查上传的文件": "twine check dist/*",
        "上传到PyPI": "twine upload dist/*"
    }
}